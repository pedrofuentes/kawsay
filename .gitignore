# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Compiled whisper-cli binaries — built from source in CI (ADR-0027 / #129),
# never committed; the per-arch subdirs are bundled by electron-builder.
# resources/whisper/README.md is kept; the binaries and work dir are not.
/.whisper-build/
/resources/whisper/*/

# Staged ffmpeg + ffprobe binaries (#175) — copied per-arch from the
# @ffmpeg-installer / @ffprobe-installer packages by scripts/stage-media-binaries.mjs
# at build time, never committed; resources/media/README.md is kept, the binaries
# are not.
/.ffmpeg-build/
/resources/media/*/

# Compiled llama-embedding binaries (ADR-0029 / M4-1b) — built from pinned source
# by scripts/build-embed-cli.sh in CI, never committed; the per-arch subdirs are
# bundled by electron-builder. Mirrors the whisper-cli / media ignores above.
/.llama-build/
/resources/embed/*/

# Full offline places gazetteer (ADR-0030 / M4-2d): the ~15 MB packed
# resources/gazetteer/cities1000.ndjson is generated from GeoNames cities1000 by
# scripts/pack-gazetteer.mjs at release time and bundled by electron-builder, never
# committed (mirrors the whisper / media / embed artifact ignores above). Only the
# small representative cities1000.sample.ndjson lives in git as the offline default.
/resources/gazetteer/cities1000.ndjson

# Converted embedder GGUF + its scratch checkout/build (ADR-0029 / M4-1b) — produced
# by scripts/convert-embed-model.sh in the maintainer-gated publish-embed-model
# workflow, uploaded as a Release asset, never committed.
/.embed-model-build/

# AC-4 OS-deny whisper harness (ADR-0027 / #138): the real-binary run output is
# ephemeral and the downloaded jfk.wav + tiny model fixtures are cached in CI,
# never committed.
/.ac4-whisper-*/
/.harness-fixtures/

# M2 offline WER/RTF accuracy harness (ADR-0027 / #137): the labeled clips are
# fetched on demand (scripts/fetch-perf-fixtures.sh, sha256-verified) and the
# 466 MB `small` model is downloaded locally — neither is committed. Only
# tests/perf/fixtures/manifest.json + NOTICES.md live in git.
/.perf-fixtures/
*.ggml.bin
ggml-*.bin

# Test coverage reports
coverage/

# Playwright renderer-egress e2e (tests/e2e): the runner's HTML report, trace
# artifacts, and the throwaway Electron user-data dir are all ephemeral run
# output, never committed.
test-results/
playwright-report/
.playwright/

# Local tool state
.impeccable/
.worktrees/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
