# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Compiled whisper-cli binaries — built from source in CI (ADR-0027 / #129),
# never committed; the per-arch subdirs are bundled by electron-builder.
# resources/whisper/README.md is kept; the binaries and work dir are not.
/.whisper-build/
/resources/whisper/*/

# AC-4 OS-deny whisper harness (ADR-0027 / #138): the real-binary run output is
# ephemeral and the downloaded jfk.wav + tiny model fixtures are cached in CI,
# never committed.
/.ac4-whisper-*/
/.harness-fixtures/

# Test coverage reports
coverage/

# Local tool state
.impeccable/
.worktrees/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
