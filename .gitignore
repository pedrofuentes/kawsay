# Dependencies
node_modules/

# Build output
dist/
build/
out/

# Compiled whisper-cli binaries — built from source in CI (ADR-0027 / #129),
# never committed; the per-arch subdirs are bundled by electron-builder.
# resources/whisper/README.md is kept; the binaries and work dir are not.
/.whisper-build/
/resources/whisper/*/

# Staged ffmpeg + ffprobe binaries (#175) — copied per-arch from the
# @ffmpeg-installer / @ffprobe-installer packages by scripts/stage-media-binaries.mjs
# at build time, never committed; resources/media/README.md is kept, the binaries
# are not.
/.ffmpeg-build/
/resources/media/*/

# Compiled llama-embedding binaries (ADR-0029 / M4-1b) — built from pinned source
# by scripts/build-embed-cli.sh in CI, never committed; the per-arch subdirs are
# bundled by electron-builder. Mirrors the whisper-cli / media ignores above.
/.llama-build/
/resources/embed/*/

# AC-4 OS-deny whisper harness (ADR-0027 / #138): the real-binary run output is
# ephemeral and the downloaded jfk.wav + tiny model fixtures are cached in CI,
# never committed.
/.ac4-whisper-*/
/.harness-fixtures/

# M2 offline WER/RTF accuracy harness (ADR-0027 / #137): the labeled clips are
# fetched on demand (scripts/fetch-perf-fixtures.sh, sha256-verified) and the
# 466 MB `small` model is downloaded locally — neither is committed. Only
# tests/perf/fixtures/manifest.json + NOTICES.md live in git.
/.perf-fixtures/
*.ggml.bin
ggml-*.bin

# Test coverage reports
coverage/

# Local tool state
.impeccable/
.worktrees/

# OS / editor cruft
.DS_Store
Thumbs.db
*.log
