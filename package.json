{
  "name": "kawsay",
  "version": "0.1.0",
  "description": "A private, fully-local desktop app to gather, organize, and preserve a loved one's digital memories.",
  "author": "pedrofuentes <git@pedrofuent.es>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.renderer-test.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "dist": "pnpm rebuild:native && electron-vite build && electron-builder",
    "dist:mac": "pnpm rebuild:native && electron-vite build && electron-builder --mac dmg",
    "dist:win": "pnpm rebuild:native && electron-vite build && electron-builder --win nsis"
  },
  "dependencies": {
    "better-sqlite3": "12.9.0",
    "exifr": "^7.1.3",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "mailparser": "^3.9.11",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "3.7.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-react": "^4.7.0",
    "axe-core": "4.12.1",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^4.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "nock": "^14.0.15",
    "prettier": "^3.8.4",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "overrides": {
      "esbuild": "^0.25.0",
      "tar": "^7.5.16"
    }
  }
}
