{
  "name": "kawsay",
  "version": "0.5.0",
  "description": "A private, fully-local desktop app to gather, organize, and preserve a loved one's digital memories.",
  "author": "pedrofuentes <git@pedrofuent.es>",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.renderer-test.json && tsc --noEmit -p tsconfig.e2e.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "stage:media": "node scripts/stage-media-binaries.mjs",
    "verify": "node scripts/verify-media-binaries.mjs",
    "predev": "pnpm stage:media",
    "dist": "electron-vite build && electron-builder --publish never",
    "predist": "pnpm stage:media",
    "dist:mac": "electron-vite build && electron-builder --mac dmg zip --publish never",
    "predist:mac": "pnpm stage:media",
    "dist:win": "electron-vite build && electron-builder --win nsis --publish never",
    "predist:win": "pnpm stage:media"
  },
  "dependencies": {
    "better-sqlite3": "12.11.1",
    "exifr": "^7.1.3",
    "mailparser": "^3.9.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "yauzl": "^3.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/yauzl": "^3.4.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^3.2.6",
    "axe-core": "4.12.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "jsdom": "^29.1.1",
    "nock": "^14.0.16",
    "prettier": "^3.9.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ],
    "supportedArchitectures": {
      "os": [
        "darwin",
        "win32",
        "linux"
      ],
      "cpu": [
        "arm64",
        "x64"
      ]
    },
    "overrides": {
      "esbuild": "^0.25.0",
      "tar": "^7.5.16"
    }
  }
}
